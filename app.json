{
  "expo": {
    "name": "Chesa Sales App",
     "jsEngine": "hermes",
    "slug": "sales-app",
    "version": "6.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/chesas.png",
    "scheme": "salesapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/e74f18d3-3b49-45c2-a445-f0ced0f89538",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/images/chesas.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/ic_launcher.png",
      "bundleIdentifier": "com.chesadentalcare.salesapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/images/ic_launcher.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ic_launcher.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chesadentalcare.salesapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/adaptive-icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false,
            "googleServicesFile": "./google-services.json"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ic_launcher.png",
          "sounds": [],
          "mode": "production",
          "color": "#2563eb"
        }
      ],
      "./plugins/withNotificationManifest.js",
      "./plugins/withGoogleServices.js",
      "./plugins/withFirebaseInit.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e74f18d3-3b49-45c2-a445-f0ced0f89538"
      }
    }
  }
}
